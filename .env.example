# Copy to .env before running docker-compose up.

# --- Postgres ---
POSTGRES_USER=logistics
POSTGRES_PASSWORD=logistics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=logistics
RABBITMQ_DEFAULT_PASS=logistics
RABBITMQ_URL=amqp://logistics:logistics@rabbitmq:5672/

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=60

# --- Internal service URLs (compose network) ---
ORDER_SERVICE_URL=http://order:8000
INVENTORY_SERVICE_URL=http://inventory:8000
SHIPPING_SERVICE_URL=http://shipping:8000

# --- Production deploy (used by docker-compose.prod.yml + Caddy) ---
# A domain for automatic HTTPS (e.g. api.example.com or you.duckdns.org),
# or ":80" for plain HTTP when you only have a raw IP. See DEPLOY.md.
SITE_ADDRESS=:80
